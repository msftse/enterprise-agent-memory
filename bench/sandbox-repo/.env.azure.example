# Azure Identity (use Managed Identity in production — leave these empty)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Cosmos DB
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE=agentmemory

# Azure AI Search
AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AI_SEARCH_INDEX=agent-memory
AI_SEARCH_ADMIN_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Blob Storage
STORAGE_ACCOUNT_URL=https://your-storage.blob.core.windows.net
STORAGE_AUDIT_CONTAINER=audit-logs
STORAGE_RAW_CONTAINER=raw-observations

# App
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_PER_MINUTE=100

# Auth (set AUTH_DISABLED=true for local dev)
AUTH_AUDIENCE=
AUTH_ISSUER=
AUTH_DISABLED=true
